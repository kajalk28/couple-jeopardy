const TEAM_COLORS = {
  1: { bg: "#FF4E6A", glow: "rgba(255, 78, 106, 0.4)", name: "Team 1" },
  2: { bg: "#4E9AFF", glow: "rgba(78, 154, 255, 0.4)", name: "Team 2" },
};

export default function CouplesTrivia() {
  const [gameState, setGameState] = useState("board"); // board, question, answer, complete
  const [selectedQ, setSelectedQ] = useState(null);
  const [answeredQuestions, setAnsweredQuestions] = useState(new Set());
  const [scores, setScores] = useState({ 1: 0, 2: 0 });
  const [currentTeam, setCurrentTeam] = useState(1);
  const [showConfetti, setShowConfetti] = useState(false);
  const [animatingCell, setAnimatingCell] = useState(null);
  const [teamNames, setTeamNames] = useState({ 1: "Team 1", 2: "Team 2" });
  const [editingName, setEditingName] = useState(null);
  const [nameInput, setNameInput] = useState("");
  const boardRef = useRef(null);

  const totalQuestions = CATEGORIES.reduce((sum, cat) => sum + cat.questions.length, 0);

  useEffect(() => {
    if (answeredQuestions.size === totalQuestions) {
      setGameState("complete");
      setShowConfetti(true);
    }
  }, [answeredQuestions]);

  const handleQuestionClick = (catIdx, qIdx) => {
    const key = `${catIdx}-${qIdx}`;
    if (answeredQuestions.has(key)) return;
    setAnimatingCell(key);
    setTimeout(() => {
      setSelectedQ({ catIdx, qIdx });
      setGameState("question");
      setAnimatingCell(null);
    }, 300);
  };

  const handleShowAnswer = () => {
    setGameState("answer");
  };

  const handleScore = (team) => {
    const q = CATEGORIES[selectedQ.catIdx].questions[selectedQ.qIdx];
    setScores((prev) => ({ ...prev, [team]: prev[team] + q.value }));
    const key = `${selectedQ.catIdx}-${selectedQ.qIdx}`;
    setAnsweredQuestions((prev) => new Set([...prev, key]));
    setCurrentTeam(team === 1 ? 2 : 1);
    setGameState("board");
    setSelectedQ(null);
  };

  const handleNoScore = () => {
    const key = `${selectedQ.catIdx}-${selectedQ.qIdx}`;
    setAnsweredQuestions((prev) => new Set([...prev, key]));
    setCurrentTeam(currentTeam === 1 ? 2 : 1);
    setGameState("board");
    setSelectedQ(null);
  };

  const handleReset = () => {
    setAnsweredQuestions(new Set());
    setScores({ 1: 0, 2: 0 });
    setCurrentTeam(1);
    setGameState("board");
    setSelectedQ(null);
    setShowConfetti(false);
  };

  const startEditName = (team) => {
    setEditingName(team);
    setNameInput(teamNames[team]);
  };

  const saveName = () => {
    if (nameInput.trim()) {
      setTeamNames((prev) => ({ ...prev, [editingName]: nameInput.trim() }));
    }
    setEditingName(null);
  };

  // Confetti particles
  const ConfettiEffect = () => {
    const particles = Array.from({ length: 60 }, (_, i) => ({
      id: i,
      left: Math.random() * 100,
      delay: Math.random() * 2,
      duration: 2 + Math.random() * 3,
      color: ["#FF4E6A", "#4E9AFF", "#FFD700", "#50E3C2", "#FF6FD8", "#FFA34E"][i % 6],
      size: 6 + Math.random() * 8,
    }));
    return (
      <div style={{ position: "fixed", inset: 0, pointerEvents: "none", zIndex: 9999 }}>
        {particles.map((p) => (
          <div
            key={p.id}
            style={{
              position: "absolute",
              left: `${p.left}%`,
              top: "-10px",
              width: p.size,
              height: p.size,
              backgroundColor: p.color,
              borderRadius: Math.random() > 0.5 ? "50%" : "2px",
              animation: `confettiFall ${p.duration}s ease-in ${p.delay}s both`,
            }}
          />
        ))}
      </div>
    );
  };

  return (
    <div style={styles.wrapper}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;700&display=swap');
        
        @keyframes confettiFall {
          0% { transform: translateY(0) rotate(0deg); opacity: 1; }
          100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
        }
        @keyframes fadeInUp {
          from { opacity: 0; transform: translateY(30px); }
          to { opacity: 1; transform: translateY(0); }
        }
        @keyframes pulseGlow {
          0%, 100% { box-shadow: 0 0 20px rgba(255,215,0,0.3); }
          50% { box-shadow: 0 0 40px rgba(255,215,0,0.6); }
        }
        @keyframes cellPop {
          0% { transform: scale(1); }
          50% { transform: scale(1.15); }
          100% { transform: scale(0); opacity: 0; }
        }
        @keyframes slideIn {
          from { opacity: 0; transform: scale(0.9); }
          to { opacity: 1; transform: scale(1); }
        }
        @keyframes shimmer {
          0% { background-position: -200% 0; }
          100% { background-position: 200% 0; }
        }
        @keyframes float {
          0%, 100% { transform: translateY(0px); }
          50% { transform: translateY(-6px); }
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
      `}</style>

      {showConfetti && <ConfettiEffect />}

      {/* Header */}
      <div style={styles.header}>
        <div style={styles.titleArea}>
          <h1 style={styles.title}>Couples Trivia</h1>
          <div style={styles.subtitle}>JEOPARDY EDITION</div>
        </div>
      </div>

      {/* Scoreboard */}
      <div style={styles.scoreboard}>
        {[1, 2].map((team) => (
          <div
            key={team}
            style={{
              ...styles.scoreCard,
              border: currentTeam === team && gameState === "board" ? `3px solid ${TEAM_COLORS[team].bg}` : "3px solid transparent",
              boxShadow: currentTeam === team && gameState === "board" ? `0 0 25px ${TEAM_COLORS[team].glow}` : "0 4px 20px rgba(0,0,0,0.3)",
              animation: currentTeam === team && gameState === "board" ? "float 2s ease-in-out infinite" : "none",
            }}
          >
            <div style={{ ...styles.teamIndicator, background: TEAM_COLORS[team].bg }} />
            {editingName === team ? (
              <div style={styles.nameEditWrap}>
                <input
                  value={nameInput}
                  onChange={(e) => setNameInput(e.target.value)}
                  onKeyDown={(e) => e.key === "Enter" && saveName()}
                  onBlur={saveName}
                  autoFocus
                  style={styles.nameInput}
                  maxLength={16}
                />
              </div>
            ) : (
              <div style={styles.teamName} onClick={() => startEditName(team)}>
                {teamNames[team]} ✏️
              </div>
            )}
            <div style={{ ...styles.scoreNum, color: TEAM_COLORS[team].bg }}>
              ${scores[team].toLocaleString()}
            </div>
          </div>
        ))}
      </div>

      {/* Turn indicator */}
      {gameState === "board" && (
        <div style={{ ...styles.turnBanner, background: TEAM_COLORS[currentTeam].bg }}>
          {teamNames[currentTeam]}'s Pick
        </div>
      )}

      {/* Game Board */}
      {gameState === "board" && (
        <div style={styles.boardContainer} ref={boardRef}>
          <div style={styles.board}>
            {CATEGORIES.map((cat, catIdx) => (
              <div key={catIdx} style={styles.column}>
                <div style={styles.categoryHeader}>
                  <span style={styles.categoryText}>{cat.name}</span>
                </div>
                {cat.questions.map((q, qIdx) => {
                  const key = `${catIdx}-${qIdx}`;
                  const answered = answeredQuestions.has(key);
                  const isAnimating = animatingCell === key;
                  return (
                    <div
                      key={qIdx}
                      onClick={() => !answered && handleQuestionClick(catIdx, qIdx)}
                      style={{
                        ...styles.cell,
                        ...(answered ? styles.cellAnswered : {}),
                        ...(isAnimating ? { animation: "cellPop 0.3s ease-in forwards" } : {}),
                        cursor: answered ? "default" : "pointer",
                      }}
                      onMouseEnter={(e) => {
                        if (!answered) {
                          e.currentTarget.style.transform = "scale(1.05)";
                          e.currentTarget.style.boxShadow = "0 0 20px rgba(255,215,0,0.5)";
                        }
                      }}
                      onMouseLeave={(e) => {
                        if (!answered) {
                          e.currentTarget.style.transform = "scale(1)";
                          e.currentTarget.style.boxShadow = "none";
                        }
                      }}
                    >
                      {!answered && (
                        <span style={styles.cellValue}>${q.value}</span>
                      )}
                    </div>
                  );
                })}
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Question View */}
      {gameState === "question" && selectedQ && (
        <div style={styles.overlay} onClick={handleShowAnswer}>
          <div style={{ ...styles.questionCard, animation: "slideIn 0.4s ease" }} onClick={(e) => e.stopPropagation()}>
            <div style={styles.qCategory}>
              {CATEGORIES[selectedQ.catIdx].name}
            </div>
            <div style={styles.qValue}>
              ${CATEGORIES[selectedQ.catIdx].questions[selectedQ.qIdx].value}
            </div>
            <div style={styles.qText}>
              {CATEGORIES[selectedQ.catIdx].questions[selectedQ.qIdx].question}
            </div>
            <button style={styles.revealBtn} onClick={handleShowAnswer}>
              Reveal Answer
            </button>
          </div>
        </div>
      )}

      {/* Answer View */}
      {gameState === "answer" && selectedQ && (
        <div style={styles.overlay}>
          <div style={{ ...styles.answerCard, animation: "slideIn 0.4s ease" }}>
            <div style={styles.qCategory}>
              {CATEGORIES[selectedQ.catIdx].name} — ${CATEGORIES[selectedQ.catIdx].questions[selectedQ.qIdx].value}
            </div>
            <div style={styles.answerLabel}>ANSWER</div>
            <div style={styles.answerText}>
              {CATEGORIES[selectedQ.catIdx].questions[selectedQ.qIdx].answer}
            </div>
            <div style={styles.whoGotIt}>Who got it right?</div>
            <div style={styles.scoreBtns}>
              {[1, 2].map((team) => (
                <button
                  key={team}
                  onClick={() => handleScore(team)}
                  style={{ ...styles.teamBtn, background: TEAM_COLORS[team].bg }}
                  onMouseEnter={(e) => (e.currentTarget.style.transform = "scale(1.08)")}
                  onMouseLeave={(e) => (e.currentTarget.style.transform = "scale(1)")}
                >
                  {teamNames[team]}
                </button>
              ))}
            </div>
            <button onClick={handleNoScore} style={styles.noOneBtn}>
              No one got it
            </button>
          </div>
        </div>
      )}

      {/* Game Complete */}
      {gameState === "complete" && (
        <div style={styles.overlay}>
          <div style={{ ...styles.completeCard, animation: "slideIn 0.5s ease" }}>
            <div style={styles.completeEmoji}>🏆</div>
            <div style={styles.completeTitle}>Game Over!</div>
            <div style={styles.finalScores}>
              {[1, 2].map((team) => (
                <div key={team} style={styles.finalScoreItem}>
                  <span style={{ color: TEAM_COLORS[team].bg, fontWeight: 700, fontSize: 20 }}>
                    {teamNames[team]}
                  </span>
                  <span style={styles.finalScoreNum}>${scores[team].toLocaleString()}</span>
                </div>
              ))}
            </div>
            <div style={styles.winnerText}>
              {scores[1] > scores[2]
                ? `🎉 ${teamNames[1]} Wins! 🎉`
                : scores[2] > scores[1]
                ? `🎉 ${teamNames[2]} Wins! 🎉`
                : "It's a Tie! 🤝"}
            </div>
            <button onClick={handleReset} style={styles.playAgainBtn}>
              Play Again
            </button>
          </div>
        </div>
      )}
    </div>
  );
}

